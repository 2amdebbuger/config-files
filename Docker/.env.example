# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# ── Project ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ecommerce

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wpuser
DB_PASSWORD=change_this_db_password
DB_ROOT_PASSWORD=change_this_root_password
DB_TABLE_PREFIX=wp_

# ── WordPress Admin ───────────────────────────────────────────────────────────
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_this_admin_password
WP_ADMIN_EMAIL=admin@yourdomain.com
WP_DEBUG=0

# ── Store Details (fill in per assignment) ────────────────────────────────────
SITE_TITLE=My Store
SITE_URL=http://localhost
STORE_COUNTRY=ZA
STORE_CITY=Johannesburg
STORE_CURRENCY=ZAR
STORE_CURRENCY_POS=left
STORE_ADDRESS=123 Main Street

# ── Ports ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80
PMA_PORT=8081
MAIL_UI_PORT=8025
