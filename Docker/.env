# Start the services
# docker compose up -d
# docker compose run --rm setup

# Stop all services
# docker compose down -v

# Re-run setup after .env changes
# docker compose run --rm setup

# Wipe everything and start fresh
# docker compose down -v && docker compose up -d && docker compose run --rm setup

